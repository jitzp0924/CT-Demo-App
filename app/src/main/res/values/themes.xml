<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.JitDemo" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/bank_dark_primary</item>
        <item name="colorPrimaryVariant">@color/bank_dark_secondary</item>
        <item name="colorOnPrimary">@color/bank_light_blue</item>
        <item name="android:colorBackground">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/bank_light_primary</item>
        <item name="colorSecondaryVariant">@color/bank_light_secondary</item>
        <item name="colorOnSecondary">@color/bank_light_orange</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>


    <!--
      Splash screen theme.
      Sets windowBackground to the brand colour so the very first frame Android
      draws (before setContentView runs) already matches the splash layout.
      This eliminates the white flash that appears when the default app theme
      is inherited.
    -->
    <style name="Theme.JitDemo.Splash" parent="Theme.JitDemo">
        <item name="android:windowBackground">@color/bank_dark_primary</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/bank_dark_primary</item>
    </style>

</resources>