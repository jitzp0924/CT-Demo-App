<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/txn_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_merchant_icon"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txn_merchant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amazon.in"
            android:textColor="#1a1a1a"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txn_category_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Shopping • 17 Jun"
            android:textColor="#888888"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txn_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="-₹2,499"
        android:textColor="@color/bank_dark_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
