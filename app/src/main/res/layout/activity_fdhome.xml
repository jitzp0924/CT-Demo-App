<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bank_dark_primary"
        app:navigationIcon="@drawable/backbutton"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/header_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="Fixed Deposit"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/details"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/question" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Live maturity strip — updates as sliders move -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bank_dark_primary"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estimated Maturity Amount"
            android:textColor="#AAFFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/fd_live_maturity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="₹52,500"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Deposit Amount ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/bank_light_orange"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deposit Amount"
                        android:textColor="@color/bank_dark_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Amount value displayed above the slider -->
                    <TextView
                        android:id="@+id/investment_amount_display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="₹50,000"
                        android:textColor="@color/bank_dark_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/fd_deposit_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="50000"
                        android:valueFrom="5000"
                        android:valueTo="500000"
                        app:thumbColor="@color/white"
                        app:thumbStrokeColor="@color/bank_dark_primary"
                        app:thumbStrokeWidth="2dp"
                        app:trackColorActive="@color/bank_dark_primary"
                        app:trackColorInactive="@color/bank_light_orange"
                        app:labelBehavior="gone" />

                    <!-- Min / Max labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹5,000"    android:textColor="#888888" android:textSize="11sp" />
                        <View     android:layout_width="0dp"          android:layout_height="wrap_content" android:layout_weight="1" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹5,00,000" android:textColor="#888888" android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Tenure ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/bank_light_orange"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tenure"
                            android:textColor="@color/bank_dark_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/fd_tenure"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="18 months"
                            android:textColor="@color/bank_dark_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/fd_tenure_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="18"
                        android:valueFrom="6"
                        android:valueTo="60"
                        app:thumbColor="@color/white"
                        app:thumbStrokeColor="@color/bank_dark_primary"
                        app:thumbStrokeWidth="2dp"
                        app:trackColorActive="@color/bank_dark_primary"
                        app:trackColorInactive="@color/bank_light_orange"
                        app:labelBehavior="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6 months" android:textColor="#888888" android:textSize="11sp" />
                        <View     android:layout_width="0dp"          android:layout_height="wrap_content" android:layout_weight="1" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5 years"  android:textColor="#888888" android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Rate of Interest ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/bank_light_orange"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/ratingtext"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rate of Interest"
                                android:textColor="#888888"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/ratingvalue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="5.00% p.a."
                                android:textColor="@color/bank_dark_primary"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/fdrates_knowmore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/bank_light_orange"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="Rate Card ›"
                            android:textColor="@color/bank_dark_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:foreground="?attr/selectableItemBackground" />

                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/fdratesimage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/bank_light_orange"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:adjustViewBounds="true"
                            android:src="@drawable/fdrates" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Nominee ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/bank_light_orange"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nominee (optional)"
                        android:textColor="@color/bank_dark_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/nomineetext"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxStrokeColor="@color/bank_dark_primary"
                        app:hintTextColor="@color/bank_dark_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/nomineeName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Full name of nominee"
                            android:inputType="textPersonName"
                            android:imeOptions="actionDone" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Continue button ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/fdsubmit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Continue"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/bank_dark_primary"
                app:cornerRadius="12dp" />

            <View android:layout_width="match_parent" android:layout_height="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
